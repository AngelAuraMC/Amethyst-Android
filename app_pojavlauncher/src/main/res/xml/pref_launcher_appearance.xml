<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app2="http://schemas.android.com/apk/res-auto">
    <net.kdt.pojavlaunch.prefs.BackButtonPreference/>
    <PreferenceCategory android:title="@string/preference_category_launcher_appearance">

        <!-- Force landscape orientation -->
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="force_landscape"
            android:title="@string/preference_force_landscape_title"
            android:summary="@string/preference_force_landscape_summary" />

        <!-- Set custom launcher background from gallery -->
        <Preference
            android:key="set_custom_launcher_bg"
            android:title="@string/preference_set_custom_bg_title"
            android:summary="@string/preference_set_custom_bg_summary"
            android:icon="@drawable/ic_set_background" />
        <!-- Remove custom launcher background -->
        <Preference
            android:key="remove_custom_launcher_bg"
            android:title="@string/preference_remove_custom_bg_title"
            android:summary="@string/preference_remove_custom_bg_summary"
            android:icon="@drawable/ic_remove_background" />

        <!-- Colour theme presets + reset -->
        <Preference
            android:key="colour_theme_presets"
            android:title="@string/preference_colour_presets_title"
            android:summary="@string/preference_colour_presets_summary"
            android:icon="@drawable/ic_set_theme" />

        <!-- Background gradient toggle -->
        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="enable_bg_gradient"
            android:title="@string/preference_bg_gradient_title"
            android:summary="@string/preference_bg_gradient_summary"
            android:icon="@drawable/ic_toggle_bg_color" />
    </PreferenceCategory>
</PreferenceScreen>